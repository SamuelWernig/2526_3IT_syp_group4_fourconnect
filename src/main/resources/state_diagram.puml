@startuml FourConnect_State_Diagram

skinparam state {
    BackgroundColor LightGray
    BorderColor DarkGray
    FontName Arial
    ArrowColor DarkGray
    StartColor Black
    EndColor Black
}

skinparam backgroundColor White
skinparam shadowing false

[*] --> Initialisierung

state Initialisierung {
    [*] --> [*] : initBoard()\nisRedTurn = true
}

Initialisierung --> AmZug

state AmZug {
    [*] --> [*] : Spalte einlesen\nMünze setzen\nswitchCoin()
}

note right of AmZug
  Test: runJamesBond()
  [IllegalArgumentException\nbei Spalte < 0 oder > 6]
end note

AmZug --> AmZug      : winner == null\n&& count < 49

AmZug --> Spielende  : winner != null\noder count == 49

state Spielende {
    [*] --> [*] : Ergebnis ausgeben
}

note right of Spielende
  Test: redWinsInRow()
  Test: redWinsInColumn()
  Test: redWinsInLeftToRightDown()
  Test: redWinsInLeftUpToRight()
  Test: yellowWinsInRow()
  Test: yellowWinsInColumn()
  Test: fillWholeBoard()
end note

Spielende --> [*]

@enduml
